# API Configuration
API_TITLE=AI Travel Planner
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./travel_planner.db

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Gemini Configuration (Open Slot)
GEMINI_API_KEY=""

# Cache
CACHE_DIR=./cache
CACHE_TTL_HOURS=24

# CORS (comma-separated origins)
CORS_ORIGINS=*
